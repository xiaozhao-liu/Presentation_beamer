\ProvidesPackage{XLcolorBeamer}
\mode<presentation>

\definecolor{XLPrimary}{RGB}{31,58,95}
\definecolor{XLSecondary}{RGB}{74,144,164}
\definecolor{XLAccent}{RGB}{92,184,176}
\definecolor{XLAlert}{RGB}{176,80,80}
\definecolor{XLExample}{RGB}{46,139,87}
\definecolor{XLText}{RGB}{47,52,55}
\definecolor{XLMuted}{RGB}{105,112,119}
\definecolor{XLLight}{RGB}{247,248,250}
\definecolor{XLLine}{RGB}{218,224,230}

\setbeamercolor{normal text}{fg=XLText,bg=white}
\setbeamercolor{structure}{fg=XLPrimary}
\setbeamercolor{alerted text}{fg=XLAlert}
\setbeamercolor{example text}{fg=XLExample}
\setbeamercolor{titlelike}{fg=XLPrimary,bg=white}
\setbeamercolor{title}{fg=XLPrimary,bg=white}
\setbeamercolor{subtitle}{fg=XLSecondary,bg=white}
\setbeamercolor{author}{fg=XLText}
\setbeamercolor{date}{fg=XLMuted}
\setbeamercolor{institute}{fg=XLMuted}
\setbeamercolor{frametitle}{fg=XLPrimary,bg=white}
\setbeamercolor{framesubtitle}{fg=XLMuted,bg=white}
\setbeamercolor{block title}{fg=white,bg=XLPrimary}
\setbeamercolor{block body}{fg=XLText,bg=XLLight}
\setbeamercolor{block title alerted}{fg=white,bg=XLAlert}
\setbeamercolor{block body alerted}{fg=XLText,bg=XLLight}
\setbeamercolor{block title example}{fg=white,bg=XLExample}
\setbeamercolor{block body example}{fg=XLText,bg=XLLight}
\setbeamercolor{section in toc}{fg=XLPrimary,bg=white}
\setbeamercolor{subsection in toc}{fg=XLMuted,bg=white}
\setbeamercolor{navigation symbols}{fg=XLMuted}
\setbeamercolor{footline}{fg=XLMuted,bg=white}

\mode<all>
